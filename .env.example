# Copy to .env and fill in. Never commit .env.

# --- Postgres (used by FastAPI and docker compose) ---
POSTGRES_USER=ragdog
POSTGRES_PASSWORD=ragdog
POSTGRES_DB=ragdog
POSTGRES_PORT=5432

# Admin/owner DSN (asyncpg): runs migrations and admin/maintenance. Host is
# `localhost` when running uvicorn on the laptop; switch to `postgres` in compose.
DATABASE_URL=postgresql+asyncpg://ragdog:ragdog@localhost:5432/ragdog

# Runtime app DSN: a least-privilege, NON-superuser role so Row-Level Security
# actually applies to request-path queries (ADR 0005). The role is created by the
# 0002 migration; in production set its password out-of-band and update this URL.
APP_DATABASE_URL=postgresql+asyncpg://ragdog_app:ragdog_app@localhost:5432/ragdog

# --- Auth (Google sign-in, closed allowlist) ---
# Comma-separated Google OAuth client IDs accepted as the ID-token audience
# (your web client + mobile client). Login rejects everything if this is empty.
GOOGLE_CLIENT_IDS=
# Secret for signing our own session JWTs. MUST be a long (32+ byte) random string
# in production; the in-code default is insecure and dev-only.
SESSION_JWT_SECRET=change-me-to-a-long-random-string
# Comma-separated emails that are implicitly allowed AND made admin on first login
# (bootstraps the allowlist). Everyone else must be added by an admin.
BOOTSTRAP_ADMIN_EMAILS=

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3
GENERATION_MODEL=qwen2.5:14b-instruct

# --- RAG knobs ---
CHUNK_SIZE_TOKENS=1000
CHUNK_OVERLAP_TOKENS=100
RETRIEVAL_TOP_K=8
HISTORY_TURNS=5
CITATIONS_LIMIT=3

# --- Storage ---
UPLOAD_DIR=./uploads

# --- Telegram bot ---
# Create via @BotFather, then set webhook with the secret token below.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string
# Comma-separated chat IDs allowed to talk to the bot (your own).
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Line bot ---
# Create a Messaging API channel at developers.line.biz.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# Comma-separated user IDs allowed to talk to the bot (your own).
LINE_ALLOWED_USER_IDS=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000
